generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model WatchlistItem {
  id        Int      @id @default(autoincrement())
  symbol    String   @unique
  addedAt   DateTime @default(now())
  sortOrder Int      @default(0)
}

model UserPreference {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

model ResearchReport {
  id           Int      @id @default(autoincrement())
  symbol       String
  name         String   @default("")
  sector       String   @default("")
  score        Int      @default(0)
  signal       String   @default("hold")
  summary      String   @default("")
  thesis       String   @default("")
  keyMetrics   String   @default("")
  risks        String   @default("")
  catalysts    String   @default("")
  priceTarget  Float?
  currentPrice Float?
  confidence   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([symbol])
  @@index([score])
  @@index([createdAt])
}

model TradeIdea {
  id          Int      @id @default(autoincrement())
  symbol      String
  action      String
  entryPrice  Float?
  targetPrice Float?
  stopLoss    Float?
  reasoning   String   @default("")
  timeframe   String   @default("")
  riskReward  Float?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([symbol])
  @@index([status])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  role      String
  content   String
  createdAt DateTime @default(now())
}

model AutoTradeLog {
  id           Int       @id @default(autoincrement())
  symbol       String
  action       String    // buy, sell, skip, stop_loss, take_profit
  qty          Int       @default(0)
  price        Float?
  reason       String    @default("")
  aiScore      Int?
  aiSignal     String?
  orderId      String?   // Broker order ID (Tradovate/Alpaca)
  pnl          Float?    // realized P&L — null until verified from fills
  createdAt    DateTime  @default(now())
  // Fill reconciliation: corrects P&L from actual Tradovate fills
  reconciledAt DateTime? // when P&L was verified/corrected from fills
  originalPnl  Float?    // pre-correction P&L (audit trail)
  fillPrice    Float?    // actual Tradovate fill price

  @@index([symbol])
  @@index([createdAt])
  @@index([action])
}

// Clean per-position round-trip ledger — sourced from actual broker fills (NOT the fragmented,
// partially-reconciled autoTradeLog). One row per closed position. The source of truth for win-rate
// and per-trade P&L. Populated forward by reconcileFills (Tradovate /fill/list is session-scoped, so
// history accumulates from deploy day). Money headline still uses balance delta; this is for win-rate.
model RoundTrip {
  id          Int      @id @default(autoincrement())
  mode        String   // "live" | "paper"
  symbol      String   // e.g. "NQ", "MNQ"
  direction   String   // "long" | "short"
  contracts   Int
  entryPrice  Float
  exitPrice   Float
  pnl         Float    // realized P&L from broker fills — clean
  rMultiple   Float?   // enriched later from entry stop distance
  setupType   String?  // enriched later from the matching entry log
  source      String   @default("broker_fill")
  entryFillId String
  exitFillId  String
  entryTime   DateTime
  exitTime    DateTime
  createdAt   DateTime @default(now())

  @@unique([mode, entryFillId, exitFillId])
  @@index([mode])
  @@index([symbol])
  @@index([exitTime])
}

model AgentRun {
  id              Int      @id @default(autoincrement())
  runType         String   // scan, manage, full
  stocksScanned   Int      @default(0)
  tradesPlaced    Int      @default(0)
  positionsManaged Int     @default(0)
  errors          Int      @default(0)
  summary         String   @default("")
  durationMs      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model AgentConfig {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

// ─── AI-Veto Shadow Tracker ───────────────────────────────────────────────────
// Every setup the engine graded but did NOT trade (AI-rejected, pattern-blocked,
// or no-verdict) is logged here with its would-be entry/stop/target, then marked
// to real price afterward. Answers the unmeasured question: is the AI veto saving
// money or leaving it on the table? Counterfactual — the trade never actually filled.
model ShadowTrade {
  id           String    @id @default(cuid())
  mode         String    // "live" | "demo"
  symbol       String
  direction    String    // "long" | "short"
  setupType    String
  blockReason  String    // "rejected" | "pattern_blocked" | "no_verdict"
  confidence   Float
  aiConfidence Float?
  reason       String    // grader's rationale (why it was blocked)
  entry        Float
  stop         Float
  target       Float
  createdAt    DateTime  @default(now())
  // Resolution (filled in by the shadow-resolve cron)
  status       String    @default("open") // "open" | "win" | "loss" | "expired"
  exitPrice    Float?
  rMultiple    Float?    // realized R of the counterfactual (win = +target/stop dist, loss = -1)
  exitReason   String?   // "target" | "stop" | "time_exit" | "eod"
  contracts    Int?      // how many contracts the engine would have sized at this account/risk
  dollarPnl    Float?    // counterfactual $ P&L = rMultiple × per-contract-risk × contracts
  resolvedAt   DateTime?

  @@index([mode, status])
  @@index([createdAt])
}

model VaultDocument {
  id        Int      @id @default(autoincrement())
  path      String   @unique // e.g., "Brain/market-regime.md"
  content   String   // full markdown content
  updatedAt DateTime @updatedAt
  updatedBy String   @default("system") // which agent last wrote

  @@index([path])
  @@index([updatedAt])
}

// ─── Event Bus & Orchestration ────────────────────────────────────────────────

model AgentEvent {
  id          Int      @id @default(autoincrement())
  type        String   // e.g. "trade.entry", "trade.exit", "regime.changed", "risk.breach"
  source      String   // agent that emitted: "futures-agent", "research-agent", etc.
  payload     String   @default("{}") // JSON context (instrument, pnl, details)
  processed   Boolean  @default(false) // orchestrator marks true after handling
  processedAt DateTime?
  processedBy String?  // which workflow handled it
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([processed, createdAt])
  @@index([createdAt])
  @@index([source])
}

model SessionContext {
  id        Int      @id @default(autoincrement())
  sessionId String   // date string "2026-05-22" — one per trading day
  key       String   // e.g. "btc_flash_crash", "regime_shift_pending", "consecutive_stops"
  value     String   // JSON payload
  expiresAt DateTime // auto-cleanup: midnight ET or custom TTL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, key])
  @@index([sessionId])
  @@index([expiresAt])
}

// ─── Fund Infrastructure ─────────────────────────────────────────────────────

model User {
  id              String   @id // Clerk user ID
  email           String   @unique
  name            String?
  avatarUrl       String?
  role            String   @default("owner") // owner, investor (future: investor portal)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  connections     BrokerConnection[]

  @@index([email])
}

model BrokerConnection {
  id            String   @id @default(cuid())
  userId        String
  broker        String   // "tradovate" | "alpaca"
  environment   String   @default("demo") // "demo" | "live"

  // Auth tokens
  accessToken   String?
  refreshToken  String?
  tokenExpires  DateTime?

  // Tradovate-specific
  accountId     Int?
  accountName   String?

  // Connection status
  status        String   @default("connected") // connected, expired, revoked
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, broker, environment])
  @@index([userId])
  @@index([broker])
}

// ─── Strategy / Instrument Registry (DB mirror of code-level registry) ───────
// These tables let the engine + admin UI consult a single source of truth for
// "which strategies run on which accounts with what caps". Code defines what
// strategies EXIST (src/lib/strategies/registry.ts); DB defines where they RUN.
// When tables are empty, the engine falls back to scattered code constants
// (DEMO_PRIORITY, MICRO_PRIORITY, LIVE_MAX_CONTRACTS_PER_SYMBOL).

model Instrument {
  symbol         String   @id  // root symbol (no month code) e.g. "MBT"
  assetClass     String   // "equity_index_futures" | "metals_futures" | "crypto_futures"
  exchange       String
  multiplier     Float
  tickSize       Float
  dayMarginEst   Float?   // approximate day margin in USD per contract
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([assetClass])
}

model Strategy {
  id                     String   @id  // kebab-case e.g. "mbt-nr4-daily"
  name                   String
  timeframe              String   // "1m" | "5m" | "15m" | "1h" | "4h" | "1d"
  tier                   Int      // 1 | 2 | 3 (rejected strategies aren't registered)
  description            String
  applicableSymbols      String[] // canonical symbols this strategy applies to
  codePath               String   // path to signal-logic file
  backtestPf             Float?   // backtest profit factor (overall)
  backtestTrades         Int?     // backtest sample size
  backtestPeriod         String?  // e.g. "2022-05 → 2026-05"
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  assignments            StrategyAssignment[]
  trades                 StrategyTrade[]

  @@index([tier])
}

model StrategyAssignment {
  id                     Int      @id @default(autoincrement())
  // Account identifier — for now we use the existing tradingMode keys:
  // "demo-futures" | "live-futures" | "paper-stocks" | "paper-crypto"
  accountKey             String
  strategyId             String
  status                 String   @default("observation") // "active" | "observation" | "disabled"
  maxContractsOverride   Int?     // null = use account default
  notes                  String?
  // Forward performance (denormalized for fast admin reads — updated by aggregator)
  forwardPf30d           Float?
  forwardTrades30d       Int?
  lastTradeAt            DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  strategy               Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@unique([accountKey, strategyId])
  @@index([accountKey])
  @@index([strategyId])
  @@index([status])
}

// Records every trade fired by a registered strategy — feeds forward-P&L attribution.
// Legacy trades (non-registry, from the 5m intraday library) live in AutoTradeLog only;
// this table is additive and never replaces that.
model StrategyTrade {
  id              Int      @id @default(autoincrement())
  strategyId      String
  accountKey      String   // "demo-futures" | "live-futures" | ...
  symbol          String
  direction       String   // "long" | "short"
  entryPrice      Float
  exitPrice       Float?
  contracts       Int
  pnl             Float?
  rMultiple       Float?
  stopDistance    Float
  targetDistance  Float
  status          String   @default("open") // "open" | "closed" | "stopped"
  reason          String?  // signal reason string
  openedAt        DateTime @default(now())
  closedAt        DateTime?

  strategy        Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([strategyId])
  @@index([accountKey])
  @@index([symbol])
  @@index([openedAt])
  @@index([status])
}
