{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["node"],
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_22"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npx tsx src/services/futures-realtime.ts",
    "healthcheckPath": null,
    "restartPolicyType": "ALWAYS"
  }
}
